{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dotnet: restore",
      "type": "process",
      "command": "dotnet",
      "args": [
        "restore"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet: build",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "--no-restore"
      ],
      "dependsOn": [
        "dotnet: restore"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet: test",
      "type": "process",
      "command": "dotnet",
      "args": [
        "test",
        "--no-build",
        "--verbosity",
        "normal"
      ],
      "dependsOn": [
        "dotnet: build"
      ],
      "group": "test",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet: format",
      "type": "process",
      "command": "dotnet",
      "args": [
        "format"
      ],
      "problemMatcher": []
    },
    {
      "label": "dotnet: format (verify)",
      "type": "process",
      "command": "dotnet",
      "args": [
        "format",
        "--verify-no-changes"
      ],
      "problemMatcher": []
    },
    {
      "label": "dotnet: pack",
      "type": "process",
      "command": "dotnet",
      "args": [
        "pack",
        "--no-build",
        "-o",
        "artifacts"
      ],
      "dependsOn": [
        "dotnet: build"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet: clean",
      "type": "process",
      "command": "dotnet",
      "args": [
        "clean"
      ],
      "problemMatcher": []
    },
    {
      "label": "dotnet: tool restore",
      "type": "process",
      "command": "dotnet",
      "args": [
        "tool",
        "restore"
      ],
      "problemMatcher": []
    }
  ]
}